local Tracers = {}
local function isVisible(targetPart)
    if not WallCheck then return true end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {localPlayer.Character or Workspace}
    local result = Workspace:Raycast(camera.CFrame.Position, targetPart.Position - camera.CFrame.Position, params)
    return not result or result.Instance:IsDescendantOf(targetPart.Parent)
end
isEnemy = function(plr)
    if Whitelist[plr.Name] then return false end
    if not TeamCheck then return true end
    local ok, result = pcall(function()
        if plr.Team and localPlayer.Team then
            if plr.Team ~= localPlayer.Team then return true end
            return false
        end
        local plrStats = plr:FindFirstChild("leaderstats")
        local localStats = localPlayer:FindFirstChild("leaderstats")
        if plrStats and localStats then
            local t1 = plrStats:FindFirstChild("Team") or plrStats:FindFirstChild("team") or plrStats:FindFirstChild("Guild") or plrStats:FindFirstChild("Clan")
            local t2 = localStats:FindFirstChild("Team") or localStats:FindFirstChild("team") or localStats:FindFirstChild("Guild") or localStats:FindFirstChild("Clan")
            if t1 and t2 then
                return t1.Value ~= t2.Value
            end
        end
        local a1 = plr.Character and plr.Character:GetAttribute("Team") or plr:GetAttribute("Team")
        local a2 = localPlayer.Character and localPlayer.Character:GetAttribute("Team") or localPlayer:GetAttribute("Team")
        if a1 ~= nil and a2 ~= nil then
            return a1 ~= a2
        end
        local tf1 = plr.Character and (plr.Character:FindFirstChild("TeamFolder") or plr.Character:FindFirstChild("TeamValue"))
        local tf2 = localPlayer.Character and (localPlayer.Character:FindFirstChild("TeamFolder") or localPlayer.Character:FindFirstChild("TeamValue"))
        if tf1 and tf2 then
            return tf1.Value ~= tf2.Value
        end
        return true
    end)
    if ok then return result end
    return true
end
local function getTargetPart(char)
    if not char then return nil end
    if AimPart == "Head" then
        return char:FindFirstChild("Head")
    elseif AimPart == "HumanoidRootPart" then
        return char:FindFirstChild("HumanoidRootPart")
    elseif AimPart == "Torso" then
        return char:FindFirstChild("UpperTorso") or char:FindFirstChild("LowerTorso") or char:FindFirstChild("HumanoidRootPart")
    end
    return char:FindFirstChild("Head")
end
local function getHealthColor(pct)
    if pct > 0.5 then
        return Color3.fromRGB(math.floor((1 - pct) * 2 * 255), 220, 60)
    else
        return Color3.fromRGB(220, math.floor(pct * 2 * 220), 60)
    end
end

local function updateESP()
    for _, plr in Players:GetPlayers() do
        if plr == localPlayer then continue end
        local char = plr.Character
        if not char then continue end
        if not isEnemy(plr) then
            local hl = char:FindFirstChild("Highlight_Zenith")
            if hl then hl:Destroy() end
            if Tracers[plr] then Tracers[plr].Visible = false end
            if HealthBars[plr] then
                HealthBars[plr].bg.Visible = false
                HealthBars[plr].bar.Visible = false
                HealthBars[plr].outline.Visible = false
            end
            if NameLabels[plr] then NameLabels[plr].Visible = false end
            continue
        end
        if HighlightESP then
            if not char:FindFirstChild("Highlight_Zenith") then
                local hl = Instance.new("Highlight", char)
                hl.Name = "Highlight_Zenith"
                hl.FillTransparency = 1
                hl.OutlineColor = Color3.fromRGB(255, 0, 0)
                hl.OutlineTransparency = 0
            end
        else
            local hl = char:FindFirstChild("Highlight_Zenith")
            if hl then hl:Destroy() end
        end
        if TracerESP then
            if not Tracers[plr] then
                local line = Drawing.new("Line")
                line.Thickness = TracerThickness
                line.Color = TracerColor
                line.Transparency = 1
                Tracers[plr] = line
            end
            local part = getTargetPart(char)
            if part and isVisible(part) then
                local pos, onScreen = camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    Tracers[plr].From = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y)
                    Tracers[plr].To = Vector2.new(pos.X, pos.Y)
                    Tracers[plr].Visible = true
                else
                    Tracers[plr].Visible = false
                end
            else
                Tracers[plr].Visible = false
            end
        else
            if Tracers[plr] then Tracers[plr].Visible = false end
        end
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        if HealthESP and rootPart and PlayerHealth[plr] then
            local hpData = PlayerHealth[plr]
            local pos, onScreen = camera:WorldToViewportPoint(rootPart.Position + Vector3.new(0, 3, 0))
            if onScreen then
                local healthPct = math.clamp(hpData.max > 0 and (hpData.hp / hpData.max) or 0, 0, 1)
                local barH = 40
                local barW = 4
                local bx = pos.X - barW - 6
                local by = pos.Y - barH / 2
                if not HealthBars[plr] then
                    local outline = Drawing.new("Line")
                    outline.Thickness = barW + 2
                    outline.Color = Color3.fromRGB(0, 0, 0)
                    outline.Transparency = 1
                    outline.ZIndex = 5
                    local bg = Drawing.new("Line")
                    bg.Thickness = barW
                    bg.Color = Color3.fromRGB(40, 40, 40)
                    bg.Transparency = 1
                    bg.ZIndex = 6
                    local bar = Drawing.new("Line")
                    bar.Thickness = barW
                    bar.Color = getHealthColor(healthPct)
                    bar.Transparency = 1
                    bar.ZIndex = 7
                    HealthBars[plr] = {outline=outline, bg=bg, bar=bar}
                end
                local hb = HealthBars[plr]
                hb.outline.From = Vector2.new(bx, by)
                hb.outline.To   = Vector2.new(bx, by + barH)
                hb.outline.Visible = true
                hb.bg.From = Vector2.new(bx, by)
                hb.bg.To   = Vector2.new(bx, by + barH)
                hb.bg.Visible = true
                hb.bar.From = Vector2.new(bx, by + barH * (1 - healthPct))
                hb.bar.To   = Vector2.new(bx, by + barH)
                hb.bar.Color = getHealthColor(healthPct)
                hb.bar.Visible = true
            else
                if HealthBars[plr] then
                    HealthBars[plr].bg.Visible = false
                    HealthBars[plr].bar.Visible = false
                    HealthBars[plr].outline.Visible = false
                end
            end
        else
            if HealthBars[plr] then
                HealthBars[plr].bg.Visible = false
                HealthBars[plr].bar.Visible = false
                HealthBars[plr].outline.Visible = false
            end
        end
        local nameRoot = char:FindFirstChild("HumanoidRootPart") or rootPart
        if NameESP and nameRoot then
            local pos, onScreen = camera:WorldToViewportPoint(nameRoot.Position + Vector3.new(0, 3.2, 0))
            if onScreen then
                if not NameLabels[plr] then
                    local lbl = Drawing.new("Text")
                    lbl.Size = 13
                    lbl.Font = Drawing.Fonts.GothamSemibold
                    lbl.Outline = true
                    lbl.OutlineColor = Color3.fromRGB(0, 0, 0)
                    lbl.Center = true
                    lbl.Color = Color3.fromRGB(255, 255, 255)
                    lbl.ZIndex = 8
                    NameLabels[plr] = lbl
                end
                NameLabels[plr].Text = plr.Name
                NameLabels[plr].Position = Vector2.new(pos.X, pos.Y - 16)
                NameLabels[plr].Visible = true
            else
                if NameLabels[plr] then NameLabels[plr].Visible = false end
            end
        else
            if NameLabels[plr] then NameLabels[plr].Visible = false end
        end
    end
end
