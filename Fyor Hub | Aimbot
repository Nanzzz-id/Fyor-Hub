local function CreateSocialCard(parent, platform, link, iconName)
    local card = Instance.new("Frame", parent)
    card.Size = UDim2.new(0.95, 0, 0, 52)
    card.BackgroundColor3 = WindUI.CurrentTheme.Secondary
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 18)
    local cStroke = Instance.new("UIStroke", card)
    cStroke.Color = WindUI.CurrentTheme.Border
    cStroke.Thickness = 1
    local bar = Instance.new("Frame", card)
    bar.Size = UDim2.new(0, 3, 0, 26)
    bar.Position = UDim2.new(0, 14, 0.5, -13)
    bar.BackgroundColor3 = WindUI.CurrentTheme.Accent
    Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)
    local ico = Instance.new("ImageLabel", card)
    ico.Size = UDim2.new(0, 14, 0, 14)
    ico.Position = UDim2.new(0, 26, 0.5, -7)
    ico.BackgroundTransparency = 1
    ico.ImageColor3 = WindUI.CurrentTheme.Accent
    ico.ScaleType = Enum.ScaleType.Fit
    task.spawn(function() ApplyIcon(ico, GetIcon(iconName or "link")) end)
    local platLbl = Instance.new("TextLabel", card)
    platLbl.Size = UDim2.new(0.45, 0, 0, 18)
    platLbl.Position = UDim2.new(0, 46, 0, 8)
    platLbl.BackgroundTransparency = 1
    platLbl.Text = platform
    platLbl.Font = Enum.Font.GothamBold
    platLbl.TextColor3 = WindUI.CurrentTheme.Text
    platLbl.TextSize = 11
    platLbl.TextXAlignment = Enum.TextXAlignment.Left
    local linkLbl = Instance.new("TextLabel", card)
    linkLbl.Size = UDim2.new(0.55, 0, 0, 16)
    linkLbl.Position = UDim2.new(0, 46, 0, 28)
    linkLbl.BackgroundTransparency = 1
    linkLbl.Text = link
    linkLbl.Font = Enum.Font.Gotham
    linkLbl.TextColor3 = WindUI.CurrentTheme.SubText
    linkLbl.TextSize = 9
    linkLbl.TextXAlignment = Enum.TextXAlignment.Left
    linkLbl.TextTruncate = Enum.TextTruncate.AtEnd
    local copyBtn = Instance.new("TextButton", card)
    copyBtn.Size = UDim2.new(0, 60, 0, 24)
    copyBtn.Position = UDim2.new(1, -72, 0.5, -12)
    copyBtn.BackgroundColor3 = WindUI.CurrentTheme.Accent
    copyBtn.BackgroundTransparency = 0.82
    copyBtn.Text = "Copy"
    copyBtn.Font = Enum.Font.GothamBold
    copyBtn.TextColor3 = WindUI.CurrentTheme.Accent
    copyBtn.TextSize = 10
    Instance.new("UICorner", copyBtn).CornerRadius = UDim.new(1, 0)
    local copyStroke = Instance.new("UIStroke", copyBtn)
    copyStroke.Color = WindUI.CurrentTheme.Accent
    copyStroke.Thickness = 1
    copyStroke.Transparency = 0.5
    copyBtn.MouseEnter:Connect(function() Tween(copyBtn, {Time=0.15}, {BackgroundTransparency=0.6}) end)
    copyBtn.MouseLeave:Connect(function() Tween(copyBtn, {Time=0.15}, {BackgroundTransparency=0.82}) end)
    copyBtn.MouseButton1Click:Connect(function()
        pcall(function() setclipboard(link) end)
        copyBtn.Text = "OK"
        copyBtn.TextColor3 = Color3.fromRGB(100, 220, 140)
        Tween(copyBtn, {Time=0.15}, {BackgroundTransparency=0.5})
        WindUI:Notify("Copied!", platform .. " link copied.", 2)
        task.delay(1.5, function()
            copyBtn.Text = "Copy"
            copyBtn.TextColor3 = WindUI.CurrentTheme.Accent
            Tween(copyBtn, {Time=0.15}, {BackgroundTransparency=0.82})
        end)
    end)
end
