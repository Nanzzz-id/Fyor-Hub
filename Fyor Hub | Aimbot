local function buildDropMenu()
    for _, ch in ipairs(wlDropMenu:GetChildren()) do
        if ch:IsA("TextButton") then ch:Destroy() end
    end
    local names = getPlayerNames()
    for i, name in ipairs(names) do
        local opt = Instance.new("TextButton", wlDropMenu)
        opt.Size = UDim2.new(1, 0, 0, 26)
        opt.BackgroundColor3 = WindUI.CurrentTheme.Secondary
        opt.BackgroundTransparency = 1
        opt.Text = name
        opt.Font = Enum.Font.GothamMedium
        opt.TextColor3 = WindUI.CurrentTheme.Text
        opt.TextSize = 10
        opt.ZIndex = 22
        opt.LayoutOrder = i
        opt.MouseEnter:Connect(function() Tween(opt, {Time=0.1}, {BackgroundTransparency=0.7}) end)
        opt.MouseLeave:Connect(function() Tween(opt, {Time=0.1}, {BackgroundTransparency=1}) end)
        opt.MouseButton1Click:Connect(function()
            if name ~= "(no players)" then
                selectedPlayerName = name
                wlDropdownBtn.Text = name
                wlDropdownBtn.TextColor3 = WindUI.CurrentTheme.Text
            end
            Tween(wlDropMenu, {Time=0.15}, {Size=UDim2.new(0, 120, 0, 0)})
            wlMenuOpen = false
        end)
    end
    local totalH = #names * 26
    return totalH
end

wlDropdownBtn.MouseButton1Click:Connect(function()
    if wlMenuOpen then
        Tween(wlDropMenu, {Time=0.15}, {Size=UDim2.new(0, 120, 0, 0)})
