local function getClosestFlick()
    local closest, shortest = nil, FlickFOV
    local center = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
    for _, plr in Players:GetPlayers() do
        if plr == localPlayer then continue end
        if not isEnemy(plr) then continue end
        local char = plr.Character
        local part = getTargetPart(char)
        if part and (part.Position - camera.CFrame.Position).Magnitude <= MaxDistance then
            local pos, onScreen = camera:WorldToViewportPoint(part.Position)
            if onScreen and isVisible(part) then
                local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = part
                end
            end
        end
    end
    return closest
end
local function getAimbotTarget()
    local closest, shortest = nil, AimbotFOV
    local center = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
    for _, plr in Players:GetPlayers() do
        if plr == localPlayer then continue end
        if not isEnemy(plr) then continue end
        local char = plr.Character
        local part = getTargetPart(char)
        if part then
            local pos, onScreen = camera:WorldToViewportPoint(part.Position)
            if onScreen and (not WallCheck or isVisible(part)) then
                local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = part
                end
            end
        end
    end
    return closest
end
RunService.RenderStepped:Connect(function()
    if AimbotEnabled then
        local target = getAimbotTarget()
        if target then
            local dir = (target.Position - camera.CFrame.Position).Unit
            camera.CFrame = camera.CFrame:Lerp(CFrame.lookAt(camera.CFrame.Position, camera.CFrame.Position + dir), AimbotSmooth)
        end
    end
    if FlickEnabled and tick() - LastFlick >= FlickCooldown then
        local target = getClosestFlick()
        if target then
            local dir = (target.Position - camera.CFrame.Position).Unit
            camera.CFrame = camera.CFrame:Lerp(CFrame.lookAt(camera.CFrame.Position, camera.CFrame.Position + dir), FlickStrength)
            LastFlick = tick()
        end
    end
    local radius = FOVRadius
    local show = ShowFOVCircle and (AimbotEnabled or FlickEnabled)
    local cx = camera.ViewportSize.X / 2
    local cy = camera.ViewportSize.Y / 2
    SetFOVCircle(cx, cy, radius, show)
    updateESP()
    camera.FieldOfView = PlayerFOV
end)

